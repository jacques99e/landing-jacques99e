    "verify:demo-sync": "node scripts/verify-demo-sync.mjs",
    "monitor:health": "powershell -ExecutionPolicy Bypass -File .\\scripts\\health-monitor.ps1",
    "monitor:health:once": "powershell -ExecutionPolicy Bypass -File .\\scripts\\health-monitor.ps1 -RunOnce"
  },
