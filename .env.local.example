NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# URL de l'application wazo-digital (vers laquelle rediriger apres connexion)
# Dev : http://localhost:3001  |  Prod : https://app.wazo-digital.com
NEXT_PUBLIC_APP_URL=https://app.wazo-digital.com

# Google Search Console — balise de verification (optionnel)
# Google Search Console — balise HTML (méthode alternative au TXT DNS)
# Code seul, sans le préfixe google-site-verification=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=O8HTYgIzABYbaYDx5AKntc-TF2GQlYqbYLpVrMdyfe4

# Indexation automatique (meme CRON_SECRET que l'app Vercel pour la cle IndexNow)
# CRON_SECRET=your-long-random-secret

# Indexation automatique (derive de CRON_SECRET sur l'app si non defini)
# INDEXNOW_KEY=optional-fixed-key-32-chars-hex

# E2E Playwright (optionnel — défauts = prod Vercel)
# E2E_LANDING_URL=https://wazo-digital.com
# E2E_APP_URL=https://app.wazo-digital.com
# E2E_USE_LOCAL=1  # requis pour utiliser localhost au lieu de la prod
# E2E_OWNER_EMAIL=test.owner@wazo.africa
# E2E_OWNER_PASSWORD=TestOwner2026!

# Resend — recovery password (/api/auth/recovery) + scripts pilotes
# Obligatoire en prod Landing pour « Mot de passe oublié »
# RESEND_API_KEY=re_...
# REPORT_EMAIL_FROM=Wazo Digital <onboarding@wazo-digital.com>
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  (même clé que wazo-digital)

# Cloudflare Turnstile (anti-bot Auth) — optionnel jusqu'à activation Supabase
# 1. Créer un widget : https://dash.cloudflare.com/?to=/:account/turnstile
# 2. Coller la site key ici + sur Vercel Landing (Production)
# 3. Dans Supabase → Auth → Attack Protection → Enable CAPTCHA (Turnstile) + secret key
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAA...
# MONITOR_WEBHOOK_URL=https://hooks.slack.com/...  # alertes CI monitor-production
# E2E_EMPLOYEE_EMAIL=test.employee@wazo.africa
# E2E_EMPLOYEE_PASSWORD=TestEmployee2026!
